<?xml version="1.0" encoding="utf-8"?>
<!--
  Mythara MINIMAL — Watch Face Format.

  Optimised for battery + glance-readability. Companion to Mythara
  Tactical (the cockpit face); same brand mark, opposite philosophy:
  every pixel earns its place, every animation is removed.

  INTERACTIVE:
    • Black background (full-frame OLED off).
    • Mythara rose centred at canvas-top-third — the brand mark is
      the focal element. No rotation, no pulse — saves animation
      power AND removes the "is this thing alive?" question (yes,
      that's the brand mark, not a status indicator).
    • Time HH:MM in a clean digital readout below the rose. Large
      type, lavender on black for maximum contrast.
    • Two complication slots at the bottom corners (default: HR
      left, battery right). User can long-press the face to swap
      either to date / steps / agenda / Mythara insight.

  AMBIENT (AOD / power-save):
    • Time HH:MM only, dimmer (charple instead of lavender) so it
      doesn't dominate at night and so the OLED burn-in risk is
      lower.
    • Rose collapses to a tiny outline above the time (just enough
      brand recognition to know whose face this is at a glance,
      <2% lit pixels).
    • All complications hidden — AOD is for the time, period.

  Resource-only; the Wear OS renderer draws everything. <Image>
  assets are raster PNGs (just `rose` + `preview`). Validated
  against WFF format version 2.
-->
<WatchFace width="450" height="450">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <Scene backgroundColor="#ff000000">

        <!-- ============ INTERACTIVE ============ -->

        <!-- Brand mark: 180×180 rose centred horizontally in the upper
             third of the face. Hidden in ambient (a tiny outline takes
             its place below — see AMBIENT section). -->
        <PartImage x="135" y="60" width="180" height="180">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Image resource="rose" />
        </PartImage>

        <!-- Time HH:MM — interactive variant. Large, lavender. -->
        <DigitalClock x="0" y="245" width="450" height="100">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <TimeText format="HH:mm" align="CENTER" size="96" color="#ff9b86ff" />
        </DigitalClock>

        <!-- Brand wordmark beneath the time. Very small, dim. Hidden in
             ambient (saves pixels). -->
        <PartText x="0" y="358" width="450" height="20">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Text align="CENTER" size="14" color="#ff8e8a95">MYTHARA</Text>
        </PartText>

        <!-- Complication slot 1 — bottom-left. Default: heart rate.
             User can swap via long-press + edit. Hidden in ambient. -->
        <ComplicationSlot x="50" y="385" width="80" height="60" slotId="1">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <BoundingOval x="0" y="0" width="80" height="60" />
            <DefaultProviderPolicy
                defaultSystemProvider="HEART_RATE"
                defaultSystemProviderType="SHORT_TEXT" />
            <SupportedTypes>
                <Type name="SHORT_TEXT" />
                <Type name="RANGED_VALUE" />
                <Type name="ICON" />
            </SupportedTypes>
            <Complication>
                <PartText x="0" y="20" width="80" height="20">
                    <Text align="CENTER" size="16" color="#ffeb4268">[COMPLICATION.TEXT]</Text>
                </PartText>
            </Complication>
        </ComplicationSlot>

        <!-- Complication slot 2 — bottom-right. Default: watch battery.
             User can swap via long-press + edit. Hidden in ambient. -->
        <ComplicationSlot x="320" y="385" width="80" height="60" slotId="2">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <BoundingOval x="0" y="0" width="80" height="60" />
            <DefaultProviderPolicy
                defaultSystemProvider="WATCH_BATTERY"
                defaultSystemProviderType="SHORT_TEXT" />
            <SupportedTypes>
                <Type name="SHORT_TEXT" />
                <Type name="RANGED_VALUE" />
                <Type name="ICON" />
            </SupportedTypes>
            <Complication>
                <PartText x="0" y="20" width="80" height="20">
                    <Text align="CENTER" size="16" color="#ff68ffd6">[COMPLICATION.TEXT]</Text>
                </PartText>
            </Complication>
        </ComplicationSlot>

        <!-- ============ AMBIENT (AOD) ============ -->
        <!-- Everything below is alpha=0 in interactive, alpha=255 in
             ambient — a strict crossover, never visible together with
             the interactive layers above. Minimal lit pixels for OLED
             burn-in + battery. -->

        <!-- Tiny rose outline above the time — just enough brand
             recognition. Same drawable, scaled down, dimmed via a low
             grey colour so it reads as an outline. -->
        <PartImage x="200" y="160" width="50" height="50" alpha="0">
            <Variant mode="AMBIENT" target="alpha" value="255" />
            <Image resource="rose" />
        </PartImage>

        <!-- Time HH:MM — ambient variant. Charple instead of lavender;
             slightly smaller; centred. Dim and small to minimise lit
             pixels while still being glanceable. -->
        <DigitalClock x="0" y="220" width="450" height="80" alpha="0">
            <Variant mode="AMBIENT" target="alpha" value="255" />
            <TimeText format="HH:mm" align="CENTER" size="72" color="#ff8a6fff" />
        </DigitalClock>
    </Scene>
</WatchFace>
