<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ data extraction rules. Block auto-backup of any sensitive
     surface — settings (contains MiniMax API key), Observe vault, chat history.
     Backups would otherwise sync to Google Drive on devices with backup
     enabled, leaking secrets across user accounts. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="file" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
